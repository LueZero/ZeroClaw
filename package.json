{
  "name": "zeroclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "dev": "pnpm -r --parallel --filter='./packages/*' dev",
    "test": "pnpm -r --filter='./packages/*' test",
    "test:e2e": "vitest run --config vitest.config.ts",
    "lint": "pnpm -r --filter='./packages/*' lint",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "clean": "pnpm -r --filter='./packages/*' clean"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
