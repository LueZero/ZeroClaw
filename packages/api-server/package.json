    "better-sqlite3": "^11.5.0",
    "dockerode": "^4.0.2",
    "fastify": "^5.0.0",
    "gray-matter": "^4.0.3",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^3.3.32",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
