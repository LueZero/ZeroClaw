# ZeroClaw Platform 環境變數（複製為 .env 並填入實際值）

# ── 認證 ──
JWT_SECRET=please-change-this-to-a-32-char-secret
# JWT_EXPIRES_IN=7d

# ── 資料庫 ──
# DB_DRIVER=sqlite|postgres（預設 postgres）
DB_DRIVER=postgres
# PostgreSQL 連線字串（DB_DRIVER=postgres 時使用）
# Docker 容器間用 zeroclaw-postgres；本機開發用 localhost
DATABASE_URL=postgres://zeroclaw:zeroclaw-dev@zeroclaw-postgres:5432/zeroclaw
# SQLite 路徑（DB_DRIVER=sqlite 時使用）
# SQLITE_PATH=./data/platform.db

# ── LLM Provider 金鑰 ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# ── BYOK — Copilot SDK 使用自有 OpenAI-compatible provider（繞過 Copilot quota）──
# 設定 OPENAI_API_KEY 後自動啟用 BYOK 模式，不再使用 GitHub Copilot API
BYOK_MODEL=
BYOK_BASE_URL=

# ── Opencode 認證 — 宿主機上 auth.json 所在目錄 ──
# 先執行: opencode providers login
# Windows: C:\Users\<you>\.local\share\opencode
# Linux/macOS: ~/.local/share/opencode
OPENCODE_AUTH_DIR=C:\Users\CIM\.local\share\opencode

# ── Opencode runtime 預設 model/provider ──
OPENCODE_MODEL_ID=anthropic/claude-sonnet-4-20250514
OPENCODE_PROVIDER_ID=anthropic

# ── 通訊平台 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Telegram 連線模式：polling（預設，免公開 URL）或 webhook
TELEGRAM_MODE=polling

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
# Discord 連線模式：webhook（預設）或 gateway（WSS 主動連線，免公開 URL）
DISCORD_MODE=webhook

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Slack App-Level Token（Socket Mode 需要，xapp-… 格式）
SLACK_APP_TOKEN=
# Slack 連線模式：webhook（預設）或 socket（Socket Mode，免公開 URL）
SLACK_MODE=webhook

# Microsoft Teams（Azure App Registration + Azure Bot resource）
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TENANT_ID=

# ── 容器資源 ──
# CONTAINER_IDLE_TIMEOUT_SEC=1800
# DEFAULT_CONTAINER_CPUS=1.0
# DEFAULT_CONTAINER_MEMORY=512m

# ── Session 生命週期（T-3）──
# 每用戶最多可同時持有的 active session 數量（0 = 不限）
# MAX_SESSIONS_PER_USER=20
# Session 閒置超時秒數（最後一則訊息後無活動 → 自動結束；0 = 不限）
# SESSION_IDLE_TIMEOUT_SEC=1800
# 單 session 最大訊息數（含 user + assistant；超過自動結束；0 = 不限）
# SESSION_MAX_MESSAGES=200
# 歷史 session 保留天數（超過定期清理 ended/error sessions；0 = 永久保留）
# SESSION_RETENTION_DAYS=30

# ── Docker ──
# DOCKER_SOCKET=                    # 預設: 自動偵測
# DOCKER_NETWORK=zeroclaw-net
# HOST_AGENTS_DIR=                  # Docker-in-Docker 時指定宿主機 agents 路徑

# ── 日誌 ──
# LOG_LEVEL=info
